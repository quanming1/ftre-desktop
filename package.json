{
  "name": "ftre-desktop",
  "version": "0.1.0",
  "description": "AI Agent Desktop Client - Monorepo",
  "main": "packages/electron/dist/main.js",
  "private": true,
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter @ftre/shared dev\" \"pnpm --filter @ftre/ui dev\" \"pnpm --filter @ftre/editor dev\" \"pnpm --filter @ftre/electron dev\" \"pnpm --filter @ftre/renderer dev\" \"wait-on http://127.0.0.1:50000 && electron packages/electron/dist/main.js\"",
    "storybook": "pnpm --filter @ftre/renderer storybook",
    "build": "pnpm --filter @ftre/shared build && pnpm --filter @ftre/ui build && pnpm --filter @ftre/editor build && pnpm --filter @ftre/electron build && pnpm --filter @ftre/renderer build",
    "clean": "pnpm --filter @ftre/shared clean && pnpm --filter @ftre/editor clean && pnpm --filter @ftre/electron clean && pnpm --filter @ftre/renderer clean && rm -rf node_modules",
    "pack": "npm run build && electron-builder --win --dir",
    "pack:full": "npm run build && electron-builder --win --dir -c electron-builder-full.json",
    "pack:quick": "electron-builder --win --dir -c electron-builder-full.json",
    "dist": "npm run build && electron-builder --win",
    "dist:full": "npm run build && electron-builder --win -c electron-builder-full.json",
    "dist:quick": "electron-builder --win -c electron-builder-full.json",
    "rebuild": "electron-rebuild -f -w node-pty",
    "bundle-backend": "node scripts/bundle-backend.js",
    "bundle-backend:clean": "node scripts/bundle-backend.js --clean",
    "test": "pnpm --filter @ftre/renderer test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.ftre.desktop",
    "productName": "ftre",
    "directories": {
      "output": "release"
    },
    "files": [
      "packages/electron/dist/**/*",
      "packages/renderer/dist/**/*",
      "packages/shared/dist/**/*",
      "node_modules/node-pty/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "npmRebuild": false,
    "electronDist": "node_modules/electron/dist"
  }
}
