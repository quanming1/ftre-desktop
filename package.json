{
  "name": "ai-base-desktop",
  "version": "0.1.0",
  "description": "AI Agent Desktop Client",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "clean": "node -e \"fs=require('fs');['dist','release','backend'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "build": "vite build",
    "bundle-backend": "node scripts/bundle-backend.js",
    "pack": "npm run clean && vite build && electron-builder --win --dir",
    "pack:full": "npm run clean && npm run bundle-backend && vite build && electron-builder --win --dir -c electron-builder-full.json",
    "dist": "npm run clean && vite build && electron-builder --win",
    "dist:full": "npm run clean && npm run bundle-backend && vite build && electron-builder --win -c electron-builder-full.json",
    "preview": "vite build && electron .",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "minimatch": "^9.0.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "partial-json": "^0.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "slate": "^0.123.0",
    "slate-history": "^0.113.1",
    "slate-react": "^0.123.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xterm": "^5.3.0",
    "zustand": "^5.0.11"
  },
  "build": {
    "appId": "com.aibase.desktop",
    "productName": "AI IDE",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "ipc/**/*",
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false,
    "electronDist": "node_modules/electron/dist"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "fast-check": "^4.6.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
